# Server
HOST=127.0.0.1
PORT=8787
POSTGRES_ADMIN_PASSWORD=change-this-admin-password
APP_DB_USER=resume_app
APP_DB_PASSWORD=change-this-app-password
DATABASE_URL=postgres://resume_app:change-this-app-password@127.0.0.1:5432/resume_analyzer
SESSION_TTL_SECONDS=604800
ADMIN_NAME=Resume Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisAdminPassword123

# OpenAI or OpenAI-compatible chat/completion provider.
# For OpenAI, only OPENAI_API_KEY is required.
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=
LLM_MODEL=gpt-5.5
LLM_API_STYLE=responses

# Optional separate OpenAI-compatible embedding provider.
# Leave these blank to reuse OPENAI_API_KEY and OPENAI_BASE_URL.
EMBEDDING_API_KEY=not-needed
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5-embedding
EMBEDDING_DIMENSIONS=
